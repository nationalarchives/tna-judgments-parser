{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "variables": [
      {
         "name": "get-staged-files-do-not-restage-changes",
         "command": "git",
         "args": [
            "diff",
            "--name-only",
            "--cached"
         ]
      }
   ],
   "tasks": [
      {
         "name": "dotnet-format--verify-no-changes",
         "command": "dotnet",
         "args": [
            "format",
            "tna-judgments-parser.sln",
            "--no-restore",
            "--include",
            "${get-staged-files-do-not-restage-changes}",
            "--verify-no-changes"
         ]
      },
      {
         "name": "dotnet-format",
         "command": "dotnet",
         "args": [
            "format",
            "tna-judgments-parser.sln",
            "--no-restore",
            "--include",
            "${get-staged-files-do-not-restage-changes}"
         ]
      }
   ]
}