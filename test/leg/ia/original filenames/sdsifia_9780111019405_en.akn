    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/sdsi/2013/9780111019405/impacts/2013/9780111019405/section/2" level="2"><inline name="tocHeading">Partial</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/sdsi/2013/9780111019405/impacts/2013/9780111019405/section/3" level="2"><inline name="tocHeading">*Delete as appropriate/once completed</inline></tocItem>
