                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000"><b>Costs: </b></span><span style="color:#000000"><b>35.2 (3.0 in scope)</b></span></p>
                </td>
                <td>
                  <p><span style="color:#000000"><b>Benefits: </b></span><span style="color:#000000"><b>0</b></span></p>
                </td>
                <td>
                  <p><span style="color:#000000"><b>Net: -</b></span><span style="color:#000000">35.2 (</span><span style="color:#000000"><b>-3.0 in scope)</b></span></p>
                </td>
                <td>
                  <p><span style="color:#000000">In Scope and Out of Scope</span></p>
                </td>
