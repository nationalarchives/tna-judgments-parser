                  <p><span style="color:#000000">2</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">3%</span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">Burial authority</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">0</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">0%</span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">Cremation authority</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">0</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">0%</span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">Other area of funeral sector</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">2</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">3%</span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">I don't work in the funeral sector</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">18</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">31%</span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000"><b>Total individuals</b></span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000"><b>22</b></span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000"><b>37%</b></span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:middle" rowspan="12">
                  <p><span style="color:#000000">Organisation</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">Funeral director business/ organisation</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">2</span></p>
                </td>
                <td style="vertical-align:bottom">
                  <p><span style="color:#000000">3%</span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:bottom">
