      <p class="center"><docType><b>EXPLANATORY MEMORANDUM TO</b></docType></p>
      <p class="center"><b>THE WORKING TIME (AMENDMENT) REGULATIONS</b></p>
      <p class="center"><docNumber><b>2013 No. [XXXX]</b></docNumber></p>
