        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/6" level="2"><inline name="tocHeading">6. European Convention on Human Rights</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/7" level="2"><inline name="tocHeading">7. Policy background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/8" level="2"><inline name="tocHeading">8. Consultation outcome</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/9" level="2"><inline name="tocHeading">9. Guidance</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/10" level="2"><inline name="tocHeading">10. Impact</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/11" level="2"><inline name="tocHeading">11. Regulating small business</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukdsi/2013/9780111100493/memorandum/1/paragraph/12" level="2"><inline name="tocHeading">12. Monitoring &amp; review</inline></tocItem>
