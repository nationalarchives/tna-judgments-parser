              </td>
              <td>
                <p><span style="color:#000000">Updates to requirements on shareholders and members</span></p>
              </td>
              <td>
                <p><b>No implementation needed -</b> UK law already provides for this</p>
              </td>
              <td>
                <p>Not applicable</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p><span style="color:#000000">Article 18</span></p>
              </td>
              <td>
                <p><span style="color:#000000">Updates to withdrawal of authorisation</span></p>
              </td>
              <td>
                <p><b>No implementation needed</b> – UK law already provides for this (section 55J FSMA) </p>
              </td>
              <td>
                <p>Not applicable</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p><span style="color:#000000">Article 21a(1)</span></p>
              </td>
