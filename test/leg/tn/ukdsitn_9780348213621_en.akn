              <td>
                <p><span style="color:#000000">Article 117</span></p>
              </td>
              <td>
                <p><span style="color:#000000">Updates to cooperation obligations</span></p>
              </td>
              <td>
                <p><b>No implementation needed – </b>UK law already provides for this</p>
              </td>
