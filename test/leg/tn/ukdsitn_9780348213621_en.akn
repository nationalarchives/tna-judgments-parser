              <td>
                <p><span style="color:#000000">Article 108</span></p>
              </td>
              <td>
                <p><span style="color:#000000">Updates to internal capital adequacy assessment process</span></p>
              </td>
              <td>
                <p>To be implemented through PRA rulebook</p>
              </td>
              <td>
                <p>Not applicable  </p>
              </td>
              <td>
                <p>Internal Capital Adequacy Assessment 14.4A, 14.4B, 14.5</p>
