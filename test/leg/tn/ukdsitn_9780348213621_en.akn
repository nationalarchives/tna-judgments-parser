                <p><span style="color:#212121">Article 6(1)(a) of the Financial Services and Markets Act 2000 (Regulated Activities) Order 2001/544</span></p>
              </td>
              <td>
                <p>Regulation 3</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
