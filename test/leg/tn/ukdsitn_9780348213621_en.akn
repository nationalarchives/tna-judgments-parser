              </td>
              <td>
                <p><span style="color:#000000">Updates to coordination and cooperation arrangements</span></p>
              </td>
              <td>
                <p><b>No implementation needed – </b>Amended provisions unlikely to be engaged before <span style="color:#212121">the end of the TP</span></p>
              </td>
              <td>
                <p>Not applicable</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p><span style="color:#000000">Article 116</span></p>
              </td>
              <td>
                <p><span style="color:#000000">Updates to college of supervisors</span></p>
              </td>
              <td>
                <p><b>No implementation</b><b> </b><b>needed - </b>UK law already provides for this (Capital Requirements Regulations 2013)</p>
              </td>
              <td>
                <p>Not applicable</p>
              </td>
              <td>
                <p />
              </td>
