    <mainBody>
      <level>
        <content>
          <p><b>The Seed Potatoes Regulations (Northern Ireland) 2015</b></p>
        </content>
      </level>
      <level>
        <heading><b>Transposition Note describing transposition of:</b></heading>
        <paragraph>
          <num>•</num>
          <content>
            <p>Directive 2002/56/EC (“the principle Directive”)</p>
          </content>
        </paragraph>
        <paragraph>
          <num>•</num>
          <content>
            <p>Commission Implementing Directive 2014/20/EU</p>
          </content>
        </paragraph>
        <paragraph>
          <num>•</num>
          <content>
            <p>Commission Implementing Directive 2014/21/EU</p>
          </content>
        </paragraph>
      </level>
      <paragraph>
        <content>
          <p>Transposition of the principle Directive (as amended by Commission Implementing Directive 2013/63/EU</p>
          <table uk:widths="1.55in 2.85in 2.01in">
            <tr>
              <td>
                <p><b>Article of the principle Directive</b></p>
              </td>
              <td>
                <p><b>Purpose</b></p>
                <p />
              </td>
              <td>
                <p><b>Implementation</b></p>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 1</p>
              </td>
              <td>
                <p>Application to the production with a view to marketing, and to the marketing of, seed potatoes within the EU.</p>
              </td>
              <td>
                <p>Reg. 1(2)</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 2(a)</p>
              </td>
              <td>
                <p>Definition of marketing.</p>
              </td>
              <td>
                <p>Reg. 2(1)</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 2(b)</p>
              </td>
              <td>
                <p>Definition of “basic seed potatoes”.</p>
              </td>
              <td>
                <p>Reg. 2(1); reg. 10(3)(b) and Schedules 1 and 3 (certification)</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 2(c)</p>
              </td>
              <td>
                <p>Definition of “certified Seed potatoes”.</p>
              </td>
              <td>
                <p>No transposition required by virtue of Decision 2004/3/EC, as amended by Commission Implementing Decision 2014/105/EU.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 2(d)</p>
              </td>
              <td>
                <p>Official measures.</p>
              </td>
              <td>
                <p>All official measures are undertaken by Departmental officials.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 3(1)</p>
              </td>
              <td>
                <p>Marketing of seed potatoes which have been officially certified.</p>
              </td>
              <td>
                <p>Reg. 4(1); reg. 10 and Schedules 1 (relates to Annex I standards) and 3 (relates to Annex II standards).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 3(2) and (3)</p>
              </td>
              <td>
                <p>Grading of seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 2(1) (definition of Union grade); reg. 10(5) (determination of grade) and Schedule 4 (requirements for grading).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 3(4)</p>
              </td>
              <td>
                <p>Seed potatoes produced by micropropagation.</p>
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 4</p>
              </td>
              <td>
                <p>Pre-basic seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 2(1) (definition of pre-basic seed potatoes); reg. 4 (permitting the marketing of pre-basic seed potatoes).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 5</p>
              </td>
              <td>
                <p>Requirements for certification of seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 10 and Schedules 1, 3 and 4 (certification and grading - more stringent controls applied to seed potatoes produced in Northern Ireland.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 6(1)(a)</p>
              </td>
              <td>
                <p>Marketing of seed potatoes for scientific purposes or selection work.</p>
              </td>
              <td>
                <p>Reg. 2(1) (definition of scientific and selection work seed potatoes); reg. 6</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 6(1)(b)</p>
              </td>
              <td>
                <p>Marketing of test and trial seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 2(1) (definition of test and trial seed potatoes); reg. 7 and Schedule 5.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 6(2)</p>
              </td>
              <td>
                <p>Marketing of test and trial seed potatoes.</p>
              </td>
              <td>
                <p>No transposition required. Commission Decision 2004/842/EC applies and is implemented in reg. 7.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 6(3)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 7</p>
              </td>
              <td>
                <p>Sampling of seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 18 and Schedule 6.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 8</p>
              </td>
              <td>
                <p>Separation of seed potatoes for plant health reasons.</p>
              </td>
              <td>
                <p>Regs. 9 and 17.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 9</p>
              </td>
              <td>
                <p>Prohibition on marketing seed potatoes treated with sprout inhibitors.</p>
              </td>
              <td>
                <p>Reg. 4(2).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 10(1)</p>
              </td>
              <td rowspan="2">
                <p>Size of seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 8.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 10(2)</p>
              </td>
              <td>
                <p>Reg. 8(3).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 10(3)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 11(1)</p>
              </td>
              <td>
                <p>Marketing homogenous lots of seed potatoes in closed containers or packages.</p>
              </td>
              <td>
                <p>Regs. 2(1) (definition of package or container), 9 and 12.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 11(2)</p>
              </td>
              <td>
                <p>Exception for small quantities.</p>
              </td>
              <td>
                <p>Reg. 16.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 12(1)</p>
              </td>
              <td>
                <p>Sealing of packages and containers.</p>
              </td>
              <td>
                <p>Reg. 12(1) and (3).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 12(2)</p>
              </td>
              <td>
                <p>Re-sealing of packages and containers.</p>
              </td>
              <td>
                <p>Reg. 12(2) and (3).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 12(3)</p>
              </td>
              <td>
                <p>Exemption for small packages.</p>
              </td>
              <td>
                <p>Reg. 16.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 13(1)</p>
              </td>
              <td>
                <p>Official labels and documents.</p>
              </td>
              <td>
                <p>Reg. 11 and Schedule 2.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 13(2)</p>
              </td>
              <td>
                <p>Exemption for small quantities.</p>
              </td>
              <td>
                <p>Reg. 16.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 14</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 15</p>
              </td>
              <td>
                <p>Indication of genetic modification.</p>
              </td>
              <td>
                <p>Reg. 13 and Schedule 2.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 16</p>
              </td>
              <td>
                <p>Requirement to provide details of any chemical treatment.</p>
              </td>
              <td>
                <p>Reg. 11(9).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 17</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 18</p>
              </td>
              <td>
                <p>Requirements for marketing of pre-basic seed potatoes.</p>
              </td>
              <td>
                <p>Reg. 2(1) (definition of pre-basic seed potatoes), reg. 10 and Schedules 1 and 3 (certification and grading), reg. 11 and Schedule 2 (labelling) and reg. 12 (sealing of packages and containers).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 19</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 20</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 21</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Not transposed. There is a general restriction on the import of seed potatoes from third countries in item 10 of Part A of Annex III to the Plant Health Directive (2000/29/EC). As potatoes from Switzerland are excepted from this restriction reg. 2(3) implements this exemption.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 22</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 23</p>
              </td>
              <td>
                <p>Compliance with marketing requirements.</p>
              </td>
              <td>
                <p>Reg. 18 (sampling); reg. 20 (powers of inspection and production).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 24</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 25</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 26</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 27</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 28</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 29</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 30</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 31</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>No transposition required.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Annex I</p>
              </td>
              <td rowspan="8">
                <p>Conditions to be satisfied by seed potatoes</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p>1.(a)</p>
              </td>
              <td>
                <p>Schedule 1, Part 3, para 8(c).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>1.(b)</p>
              </td>
              <td>
                <p>Schedule 1, Part 3, para 8(a).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>1.(c)</p>
              </td>
              <td>
                <p>Schedule 1, Part 3, para 7.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>1.(d)</p>
              </td>
              <td>
                <p>Schedule 1, Part 3, para 8(b).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>2</p>
              </td>
              <td>
                <p>No transposition required as certified seed potatoes may not be marketed in Northern Ireland.</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>4</p>
              </td>
              <td>
                <p>Schedule 1, Part 3, paras 7 and 8(b).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>7</p>
              </td>
              <td>
                <p>Reg. 11(6)(b); Schedule 1, Part 3, para 9(b).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Annex II</p>
              </td>
              <td rowspan="9">
                <p>Minimum quality conditions for lots of seed potatoes</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p>(1)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (viii)</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>(2)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (i).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>(3)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (vii).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>(4)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (iii).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>(5)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (ii).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>(6)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (iv).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>(7)</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (vi).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Additional test “Total tolerance ...”</p>
              </td>
              <td>
                <p>Schedule 3, Table 2, Group II, item (ix).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Annex III</p>
              </td>
              <td rowspan="3">
                <p>Labelling requirements</p>
              </td>
              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p>A</p>
              </td>
              <td>
                <p>Schedule 2, Part 1, para (3)(b).</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>B</p>
