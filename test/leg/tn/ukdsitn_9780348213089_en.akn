            <tr>
              <td>
                <p>94(2)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Section 47(1) and (2), 56, 56A, 58, and 60(2) and 63 of the Communications Act 2003</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>94(3)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Section 58(4) of the Communications Act 2003</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>94(4)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Sections 45 to 48, 58 of the Communications Act 2003</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>94(5)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Sections 45 to 48, 56, 58, and 63(1) of the Communications Act 2003  </p>
              </td>
            </tr>
            <tr>
              <td>
                <p>94(6)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Sections 45 to 48, 58, 96A-96C, 61(3) and (4) of the Communications Act 2003</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>94(7)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Section 59 of the Communications Act 2003 </p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 95</p>
              </td>
              <td>
                <p>Fees for rights of use for numering resources</p>
              </td>
              <td>
                <p>Sections 45 to 48, 58(1)(g) and (h), and 58(6) of the Communications Act 2003</p>
