            <tr>
              <td>
                <p>Article 118</p>
              </td>
              <td>
                <p>Committee</p>
              </td>
              <td>
                <p>Not required - this obligation falls on the European Commission</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 119</p>
              </td>
              <td>
                <p>Exchange of information</p>
              </td>
              <td>
                <p>Not required - this obligation falls on the European Commission</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 120</p>
              </td>
              <td>
                <p>Publication of information</p>
