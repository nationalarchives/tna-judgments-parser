              <td style="border:1pt solid #000000">
                <p>Article 123</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Specific review procedures on end user rights</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Not required – obligations fall on BEREC and the European Commission</p>
              </td>
            </tr>
            <tr>
              <td style="border:1pt solid #000000">
                <p>Article 124</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Transposition</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>To be dealt with administratively </p>
              </td>
            </tr>
            <tr>
              <td style="border:1pt solid #000000">
                <p>Article 125</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Repeal </p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Not required</p>
              </td>
            </tr>
            <tr>
              <td style="border:1pt solid #000000">
                <p>Article 126</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Entry into force  </p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Not required</p>
              </td>
            </tr>
            <tr>
              <td style="border:1pt solid #000000">
                <p>Article 127</p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Addressees </p>
              </td>
              <td style="border:1pt solid #000000">
                <p>Not required</p>
              </td>
            </tr>
          </table>
        </content>
      </level>
    </mainBody>
  </doc>
