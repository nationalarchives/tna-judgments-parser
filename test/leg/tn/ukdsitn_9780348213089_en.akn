              <td>
                <p />
              </td>
            </tr>
            <tr>
              <td>
                <p>120(1) and (2)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>To be dealt with administratively </p>
              </td>
            </tr>
            <tr>
              <td>
                <p>120(3) to (6)</p>
              </td>
              <td>
                <p />
              </td>
              <td>
                <p>Sections 24 to 26, 48(1) and (6) of the Communications Act 2003</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 121</p>
              </td>
              <td>
                <p>Notification and monitoring</p>
              </td>
              <td>
                <p>Sections 25 and 26 of the Communications Act 2003</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 122</p>
              </td>
              <td>
                <p>Review procedures</p>
              </td>
              <td>
                <p>Not required – obligations fall on BEREC and the European Commission</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 123</p>
              </td>
              <td>
                <p>Specific review procedures on end user rights</p>
