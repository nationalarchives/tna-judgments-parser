              <td>
                <p>Article 116</p>
              </td>
              <td>
                <p>Adaptation of annexes</p>
              </td>
              <td>
                <p>Not required - this is a power for the European Commission</p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 117</p>
              </td>
              <td>
                <p>Exercise of the delegation</p>
