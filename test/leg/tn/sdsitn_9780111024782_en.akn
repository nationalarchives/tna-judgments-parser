              </td>
              <td>
                <p><b>Provision </b></p>
              </td>
            </tr>
            <tr>
              <td>
                <p>Article 1</p>
              </td>
              <td>
                <p>Objective </p>
              </td>
              <td>
                <p>None required</p>
              </td>
            </tr>
            <tr>
