                <FRBRuri value="http://www.legislation.gov.uk/id/uksi/2016/518/code-of-practice/1/annex/3" />
                <FRBRdate date="2026-04-20" name="generated" />
                <FRBRauthor href="http://www.legislation.gov.uk/id/government/uk" />
                <FRBRcountry value="GB-UKM" />
              </FRBRWork>
              <FRBRExpression>
                <FRBRthis value="http://www.legislation.gov.uk/uksi/2016/518/code-of-practice/1/annex/3" />
                <FRBRuri value="http://www.legislation.gov.uk/uksi/2016/518/code-of-practice/1/annex/3" />
                <FRBRdate date="2026-04-20" name="generated" />
                <FRBRauthor href="#" />
                <FRBRlanguage language="en" />
              </FRBRExpression>
              <FRBRManifestation>
                <FRBRthis value="http://www.legislation.gov.uk/uksi/2016/518/code-of-practice/1/annex/3/data.akn" />
                <FRBRuri value="http://www.legislation.gov.uk/uksi/2016/518/code-of-practice/1/annex/3/data.akn" />
                <FRBRdate date="2026-04-20" name="historic-akn-transform" />
                <FRBRauthor href="#tna" />
