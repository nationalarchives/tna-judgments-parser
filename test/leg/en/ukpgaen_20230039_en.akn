    <preface>
      <p><b>STRIKES (MINIMUM SERVICE LEVELS) ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/39/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
