    <preface>
      <p><b>INSTITUTE FOR APPRENTICESHIPS AND TECHNICAL EDUCATION (TRANSFER OF FUNCTIONS ETC) ACT 2025</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
