          <mainBody>
            <p eId="annex_1_p_7"><b>Annex A – Territorial extent and application in the United Kingdom</b></p>
            <table uk:widths="0.75in 0.68in 0.68in 0.93in 0.82in">
              <tr>
                <th>
                  <p><b>Provision</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to Wales?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Scotland?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Northern Ireland?</b></p>
                </th>
              </tr>
