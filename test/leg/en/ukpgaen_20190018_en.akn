    <preface>
      <p><b>MENTAL CAPACITY (AMENDMENT) ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/18/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
