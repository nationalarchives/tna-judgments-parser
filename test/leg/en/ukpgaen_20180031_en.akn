    <preface>
      <p><b>HEALTH AND SOCIAL CARE (NATIONAL DATA GUARDIAN) ACT 2018</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2018/31/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2018/31/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2018/31/notes/section/2" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
