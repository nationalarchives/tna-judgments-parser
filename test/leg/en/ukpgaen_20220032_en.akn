          <mainBody>
            <p eId="annex_3_p_11"><b>Annex C - Changes to the Rehabilitation of Offenders Act 1974</b></p>
            <table uk:widths="1.3in 0.94in 0.95in 1.24in 0.92in 0.89in">
              <tr>
                <td colspan="3">
                  <p><b>Existing Regime (England &amp; Wales)</b></p>
                </td>
                <td colspan="3">
                  <p><b>Proposals for New Rehabilitation Periods (England &amp; Wales)</b></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><b>Sentence </b></p>
                </td>
                <td>
                  <p><b>Adults</b></p>
                </td>
                <td>
                  <p><b>Under 18s</b></p>
                </td>
                <td>
                  <p><b>Sentence</b></p>
                </td>
                <td>
                  <p><b>Adults</b></p>
                </td>
                <td>
                  <p><b>U18s</b></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Community order</p>
                </td>
                <td>
                  <p>12 months</p>
                </td>
                <td>
                  <p>6 months</p>
                </td>
                <td>
                  <p>Community Order</p>
                </td>
                <td>
                  <p>At end of order</p>
                </td>
                <td>
                  <p>At end of order</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Custody of 6 months or less</p>
                </td>
                <td>
                  <p>2 years</p>
                </td>
                <td>
                  <p>18 months</p>
                </td>
                <td>
                  <p>Custody of under 1 year</p>
                </td>
                <td>
                  <p>12 months</p>
                </td>
                <td>
                  <p>6 months</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Custody of between 6 months and 30 months</p>
                </td>
                <td>
                  <p>4 years</p>
                </td>
                <td>
                  <p>2 years</p>
                </td>
                <td>
                  <p>Custody of between 1 year and 4 years</p>
                </td>
                <td>
                  <p>4 years</p>
                </td>
                <td>
                  <p>2 years</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Custody of between 30 months and 4 years</p>
                </td>
                <td>
                  <p>7 years</p>
                </td>
                <td>
                  <p>3.5 years</p>
                </td>
                <td>
                  <p>Custody of more than 4 years†</p>
                </td>
                <td>
                  <p>7 years</p>
                </td>
                <td>
                  <p>3.5 years</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Custody of more than 4 years</p>
                </td>
                <td>
                  <p>Conviction is never spent</p>
                </td>
                <td>
                  <p>Conviction is never spent</p>
                </td>
                <td>
                  <p />
                </td>
                <td>
                  <p />
                </td>
                <td>
                  <p />
                </td>
              </tr>
            </table>
            <blockContainer>
              <num>•</num>
              <p>† = Excluding serious violent, sexual or terrorist offences, that continue to never be spent.</p>
            </blockContainer>
          </mainBody>
        </doc>
      </attachment>
