          <mainBody>
            <p eId="annex_4_p_12"><b>Annex D - Territorial extent and application in the United Kingdom</b></p>
            <table uk:widths="1.08in 1.18in 1.16in 0.9in 0.98in">
              <tr>
                <th>
                  <p><b>Provision</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </th>
                <th>
