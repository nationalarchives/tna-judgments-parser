    <preface>
      <p><b>SOCIAL SECURITY (ADDITIONAL PAYMENTS) ACT 2022</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/38/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/38/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/38/notes/section/2" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/38/notes/section/3" level="2"><inline name="tocHeading">Legal background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/38/notes/section/4" level="2"><inline name="tocHeading">Territorial extent and application</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/38/notes/section/5" level="2"><inline name="tocHeading">Commentary on provisions of Act</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Means-tested additional payments</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Administration etc</inline></tocItem>
