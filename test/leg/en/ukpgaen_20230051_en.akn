    <preface>
      <p><b>WORKER PROTECTION (AMENDMENT OF EQUALITY ACT 2010) ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/51/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
