                  <p><span style="color:#000000"><b>Provision</b></span><span style="color:#000000"> </span></p>
                </td>
                <td>
                  <p><span style="color:#000000"><b>Extends to E &amp; W and applies to England?</b></span><span style="color:#000000"> </span></p>
                </td>
                <td>
                  <p><span style="color:#000000"><b>Extends to E &amp; W and applies to Wales?</b></span><span style="color:#000000"> </span></p>
