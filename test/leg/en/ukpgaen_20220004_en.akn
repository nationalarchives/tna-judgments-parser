    <preface>
      <p><b>ADVANCED RESEARCH AND INVENTION AGENCY</b><b> </b><b>ACT 2022</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/4/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/4/notes/section/1" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
        <tocItem href="#section_1" level="3"><inline name="tocHeading">ARIA model</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/4/notes/section/2" level="2"><inline name="tocHeading">Legal background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/4/notes/section/3" level="2"><inline name="tocHeading">Territorial extent and application</inline></tocItem>
