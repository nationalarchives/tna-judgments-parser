          <mainBody>
            <p><span style="color:#0070C0"><b>Annex A - Hansard References</b></span></p>
            <blockContainer>
              <num>85 </num>
              <p><span style="color:#000000">The following table sets out the dates and Hansard references for each stage of the Act's passage through Parliament.</span></p>
            </blockContainer>
            <table uk:widths="1.75in 1.48in 3.22in">
              <tr>
                <th>
                  <p><span style="color:#000000"><b>Stage</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Date</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Hansard Reference</b></span></p>
                </th>
              </tr>
              <tr>
                <td colspan="3">
                  <p><span style="color:#000000"><i>House of Commons</i></span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Introduction</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">19 July 2017</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2017-07-19/debates/AE667929-DA6E-4938-9928-FE573D5D0F3A/PointsOfOrder"><span style="color:#0070C0"><u>Vol. 627 Col. 877</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Second Reading</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">19 January 2018</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2018-01-19/debates/5790FBB0-8E5E-4FD1-AE3C-665095381180/StalkingProtectionBill"><span style="color:#0070C0"><u>Vol. 634 Col. 1229</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Public Bill Committee</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">9 July 2018</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2018-07-09/debates/e048f8e0-a73d-4584-9a55-d4d325cf1bde/StalkingProtectionBill(FirstSitting)"><span style="color:#0070C0"><u>Vol. 644 Col. 1</u></span></a></p>
