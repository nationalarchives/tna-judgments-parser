        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 2: Power to make Orders</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 3: Duration of orders</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 4: Variations, renewals and discharges</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 5: Interim stalking protection Orders</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 6: Content of Orders</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 7: Appeals</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 8: Offence of breaching stalking protection order etc.</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 9: Notification requirements</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 10: Method of notification and related matters</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 11: Offences relating to notification</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 12: Guidance</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 13: Procedure</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 14: Interpretation</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 15: Extent, commencement and short title</inline></tocItem>
