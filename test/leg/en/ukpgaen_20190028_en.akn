    <preface>
      <p><b>CENSUS (RETURN PARTICULARS AND REMOVAL OF PENALTIES)</b><b> </b><b>ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/28/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
