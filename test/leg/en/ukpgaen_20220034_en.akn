    <preface>
      <p><b>BRITISH SIGN LANGUAGE</b><b> </b><b>ACT 2022</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/34/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
