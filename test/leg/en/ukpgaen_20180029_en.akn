    <preface>
      <p><b>CIVIL LIABILITY ACT 2018</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2018/29/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
