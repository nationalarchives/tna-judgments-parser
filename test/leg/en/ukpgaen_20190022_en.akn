    <preface>
      <p><b>NORTHERN IRELAND (EXECUTIVE FORMATION ETC)</b><b> </b><b>ACT</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/22/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
