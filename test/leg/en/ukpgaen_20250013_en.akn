    <preface>
      <p><b>STEEL INDUSTRY (SPECIAL MEASURES)</b><span style="color:#000000"><b> </b></span><b>ACT 2025</b></p>
      <p><span style="color:#000000">EXPLANATORY NOTES</span></p>
    </preface>
    <mainBody>
