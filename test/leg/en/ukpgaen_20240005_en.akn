                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2024-03-13/debates/F2155AEA-F281-4DC6-92ED-2D14A83072C5/NationalInsuranceContributions(ReductionInRates)(No2)Bill"><span style="color:#000000"><u>Vol. 747 Col. 374</u></span></a></p>
                </td>
