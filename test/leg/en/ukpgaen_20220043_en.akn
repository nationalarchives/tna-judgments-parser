                  <p>Royal Assent</p>
                </td>
                <td rowspan="2">
                  <p>25 October 2022</p>
                </td>
                <td>
                  <p>House of Commons <a href="https://hansard.parliament.uk/Commons/2022-10-25/debates/246DE276-1887-475F-8016-DB81309C6D81/RetainedEULaw(RevocationAndReform)Bill"><u>Vol. 721 Col. 247</u></a></p>
                </td>
