        <tocItem href="#section_3" level="3"><inline name="tocHeading">Assimilated law on the welfare of animals in transport</inline></tocItem>
        <tocItem href="#section_3" level="3"><inline name="tocHeading">Animal Health Act 1981</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2024/11/notes/section/4" level="2"><inline name="tocHeading">Territorial extent and application</inline></tocItem>
