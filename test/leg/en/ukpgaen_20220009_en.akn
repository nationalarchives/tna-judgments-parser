    <preface>
      <p><span style="color:#000000"><b>NATIONAL INSURANCE CONTRIBUTIONS ACT 2022</b></span></p>
      <p><span style="color:#000000">EXPLANATORY NOTES</span></p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes/section/2" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes/section/3" level="2"><inline name="tocHeading">Legal background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes/section/4" level="2"><inline name="tocHeading">Territorial extent and application</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes/section/5" level="2"><inline name="tocHeading">Commentary on provisions of the Act</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Part 1: Secondary Class 1 Contributions</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Freeports</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Veterans</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Upper secondary threshold</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Part 2: Class 4 Contributions</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Part 3: Disclosure of Avoidance</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Part 4: General</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/9/notes/section/6" level="2"><inline name="tocHeading">Commencement</inline></tocItem>
