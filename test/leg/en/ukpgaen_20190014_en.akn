    <preface>
      <p><b>HEALTHCARE (EUROPEAN ECONOMIC AREA AND SWITZERLAND ARRANGEMENTS)</b><b> </b><b>ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
