    <preface>
      <p><b>IMMIGRATION AND SOCIAL SECURITY CO-ORDINATION (EU WITHDRAWAL)</b><b> </b><b>ACT 2020</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/20/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
