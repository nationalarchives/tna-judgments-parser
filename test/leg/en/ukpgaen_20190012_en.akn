    <preface>
      <p><b>CIVIL PARTNERSHIPS, MARRIAGES AND DEATHS (REGISTRATION ETC.)</b><b> </b><b>ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/12/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
