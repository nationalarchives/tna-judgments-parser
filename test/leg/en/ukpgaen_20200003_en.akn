          <mainBody>
            <p><span style="color:#0070C0"><b>Annex B – Hansard References</b></span></p>
            <blockContainer>
              <num>59.</num>
              <p><span style="color:#000000">The following table sets out the dates and Hansard references for each stage of the Act’s passage through Parliament. </span></p>
            </blockContainer>
            <table uk:widths="1.95in 1.9in 1.94in">
              <tr>
                <td>
                  <p><span style="color:#000000"><b>Stage</b></span></p>
                </td>
                <td>
                  <p><span style="color:#000000"><b>Date</b></span></p>
                </td>
                <td>
                  <p><span style="color:#000000"><b>Hansard Reference</b></span></p>
                </td>
              </tr>
              <tr>
                <td colspan="3">
                  <p><span style="color:#000000"><i>House of Commons</i></span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">First Reading</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">11 February 2020</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">No debate</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Second Reading</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">12 February 2020</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2020-02-12/debates/724D0060-A340-4F55-9566-8D5079993A2D/TerroristOffenders(RestrictionOfEarlyRelease)Bill"><span style="color:#000000"><u>Vol.671 Col.863</u></span></a><span style="color:#000000"> </span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Committee of the Whole House</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">12 February 2020</span></p>
