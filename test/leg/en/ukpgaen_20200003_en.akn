    <preface>
      <p><span style="color:#000000"><b>TERRORIST OFFENDERS (RESTRICTION OF EARLY RELEASE) ACT 2020</b></span></p>
      <p><span style="color:#000000">EXPLANATORY NOTES</span></p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/3/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/3/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/3/notes/section/2" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
