    <preface>
      <p><b>CHILDREN ACT 1989 (AMENDMENT) (FEMALE GENITAL MUTILATION) ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/10/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
