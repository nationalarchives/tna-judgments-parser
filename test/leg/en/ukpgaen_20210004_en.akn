    <preface>
      <p><b>COVERT HUMAN INTELLIGENCE SOURCES (CRIMINAL CONDUCT) ACT 2021</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2021/4/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
