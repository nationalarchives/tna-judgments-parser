          <mainBody>
            <p><span style="color:#0070C0"><b>Annex A – Glossary</b></span></p>
            <table uk:widths="3.14in 3.15in">
              <tr>
                <td>
                  <p><span style="color:#000000">Affirmative procedure</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Statutory instruments that are subject to the draft “affirmative procedure” must be approved by both the House of Commons and House of Lords to become law.</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">CHIS</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Covert Human Intelligence Source</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">RIPA</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Regulation of Investigatory Powers Act 2000</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">RIP(S)A</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Regulation of Investigatory Powers (Scotland) Act 2000</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">The Code</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Covert Human Intelligence Sources Revised Code of Practice, August 2018</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">UK</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">United Kingdom of Great Britain and Northern Ireland</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Participation</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Participation in criminal conduct </span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Relevant criminal conduct</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Criminal conduct in the course of, or otherwise in connection with, the conduct of the use of a CHIS</span></p>
                </td>
              </tr>
            </table>
          </mainBody>
        </doc>
