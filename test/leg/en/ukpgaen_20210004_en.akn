      <attachment>
        <doc name="annex">
          <meta>
            <identification source="#tna">
              <FRBRWork>
                <FRBRthis value="http://www.legislation.gov.uk/id/ukpga/2021/4/notes/annex/2" />
                <FRBRuri value="http://www.legislation.gov.uk/id/ukpga/2021/4/notes/annex/2" />
                <FRBRdate date="2026-05-01" name="generated" />
                <FRBRauthor href="http://www.legislation.gov.uk/id/legislature/UnitedKingdomParliament" />
                <FRBRcountry value="GB-UKM" />
              </FRBRWork>
              <FRBRExpression>
                <FRBRthis value="http://www.legislation.gov.uk/ukpga/2021/4/notes/annex/2" />
                <FRBRuri value="http://www.legislation.gov.uk/ukpga/2021/4/notes/annex/2" />
                <FRBRdate date="2026-05-01" name="generated" />
                <FRBRauthor href="#" />
                <FRBRlanguage language="en" />
              </FRBRExpression>
              <FRBRManifestation>
                <FRBRthis value="http://www.legislation.gov.uk/ukpga/2021/4/notes/annex/2/data.akn" />
                <FRBRuri value="http://www.legislation.gov.uk/ukpga/2021/4/notes/annex/2/data.akn" />
