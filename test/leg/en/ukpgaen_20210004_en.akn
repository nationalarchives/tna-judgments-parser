              </FRBRManifestation>
            </identification>
          </meta>
          <mainBody>
            <p><span style="color:#0070C0"><b>Annex B – Territorial extent and application in the United Kingdom</b></span></p>
            <blockContainer>
              <num>81 </num>
              <p><span style="color:#000000">The provisions in this Act form part of the law of England, Wales, Northern Ireland and Scotland. The Act extends to the UK apart from activity relating to devolved matters in Scotland. Subject to that, the Act will apply UK-wide.</span></p>
            </blockContainer>
            <table uk:widths="1.24in 1.12in 1.12in 1.12in 1.53in">
              <tr>
                <th>
                  <p><span style="color:#000000"><b>Provision</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Extends to E &amp; W and applies to England?</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Extends to E &amp; W and applies to Wales?</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Extends and applies to Scotland?</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Extends and applies to Northern Ireland?</b></span></p>
                </th>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Section 1 </span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">In part </span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Section 2 </span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">In part </span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                </td>
