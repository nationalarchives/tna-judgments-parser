    <preface>
      <p><b>MEDICINES AND MEDICAL DEVICES</b><span style="color:#000000"><b> </b></span><b>ACT 2021</b></p>
      <p><span style="color:#000000">EXPLANATORY NOTES</span></p>
    </preface>
    <mainBody>
