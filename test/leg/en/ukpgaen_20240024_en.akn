          <mainBody>
            <p><span style="color:#0070C0"><b>Annex A - Hansard References</b></span></p>
            <blockContainer>
              <num>28 </num>
              <p><span style="color:#000000">The following table sets out the dates and Hansard references for each stage of the Act's passage through Parliament. </span></p>
            </blockContainer>
            <table uk:widths="1.75in 1.48in 3.22in">
              <tr>
                <th>
                  <p><span style="color:#000000"><b>Stage</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Date</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Hansard Reference</b></span></p>
                </th>
              </tr>
              <tr>
                <td colspan="3">
                  <p><span style="color:#000000"><i>House of Commons</i></span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Introduction</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">18 July 2024</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2024-07-18/debates/BD0244AE-DE32-4AB3-B09E-1E3751D5F910/PointsOfOrder"><span style="color:#0070C0"><u>Vol. [752] Col. [212]</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Second Reading</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">30 July 2024</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2024-07-30/debates/D06173A9-48EC-4D52-B19F-3B220E128EF9/BudgetResponsibilityBill"><span style="color:#0070C0"><u>Vol. [752] Col. [1211]</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Committee of the Whole House</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">04 September 2024</span></p>
