                  <p><span style="color:#000000">Royal Assent</span></p>
                </td>
                <td rowspan="2">
                  <p><span style="color:#000000">22 July 2020</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">House of Commons </span><a href="https://hansard.parliament.uk/Lords/2020-07-22/debates/4819BE33-24A9-48F8-BE5A-BB0FA4D69EB5/RoyalAssent"><span style="color:#0070C0"><u>Vol. 678 Col. 2168</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">House of Lords </span><a href="https://hansard.parliament.uk/Lords/2020-07-22/debates/4819BE33-24A9-48F8-BE5A-BB0FA4D69EB5/RoyalAssent"><span style="color:#0070C0"><u>Vol. 804 Col. 2201</u></span></a></p>
                </td>
              </tr>
            </table>
          </content>
        </paragraph>
      </section>
