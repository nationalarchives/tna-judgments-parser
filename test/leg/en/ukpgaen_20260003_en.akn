                  <p><a href="https://bills.parliament.uk/publications/50746/documents/4059"><span style="color:#0070C0"><u>Transcript AM</u></span></a><span style="color:#0070C0"><u> and </u></span><a href="https://bills.parliament.uk/publications/50751/documents/4060"><span style="color:#0070C0"><u>Transcript PM</u></span></a></p>
                  <p><a href="https://bills.parliament.uk/publications/51256/documents/4061"><span style="color:#000000"><u>Transcript</u></span></a></p>
                  <p><a href="https://bills.parliament.uk/publications/51224/documents/3620"><span style="color:#000000"><u>Report</u></span></a><span style="color:#000000"> </span></p>
