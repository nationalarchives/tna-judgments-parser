    <preface>
      <p><b>BUSINESS AND PLANNING ACT 2020</b></p>
      <p><span style="color:#000000">EXPLANATORY NOTES</span></p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/16/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
