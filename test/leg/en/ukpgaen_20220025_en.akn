                </th>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Section 1</span></p>
                  <p><span style="color:#000000">(Retained EU law relating to compulsory insurance for motor vehicles)</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                  <p />
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                  <p />
                </td>
                <td>
                  <p><span style="color:#000000">Yes</span></p>
                  <p />
                </td>
                <td>
                  <p><span style="color:#000000">No</span></p>
                  <p />
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Section 2</span></p>
                  <p><span style="color:#000000">(Commencement, extent and short title)</span></p>
