                </td>
                <td>
                  <p><b>Bill as amended in Committee in the Lords</b></p>
                </td>
                <td>
                  <p><b>Bill as amended on Report in the Lords</b></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 1</p>
                </td>
                <td>
                  <p>Clause 1</p>
