    <preface>
      <p><b>EDUCATION (CAREERS GUIDANCE IN SCHOOLS)</b><b> </b><b>ACT 2022</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/13/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
