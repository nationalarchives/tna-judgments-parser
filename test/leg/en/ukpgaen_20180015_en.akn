          <mainBody>
            <p eId="annex_1_p_8"><b>Annex A - Territorial extent and application in the United Kingdom</b></p>
            <table uk:widths="1.88in 1.08in 1.08in 1.08in 1.19in">
              <tr>
                <th>
                  <p><b>Provision</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to Wales?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Scotland?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Northern Ireland?</b></p>
                </th>
              </tr>
              <tr>
                <td>
                  <p>1 Nuclear Safeguards</p>
                  <p>2 Power to amend legislation relating to nuclear safeguards</p>
                  <p>3 Report on nuclear safeguards</p>
                  <p>4 Request for continuation of existing agreements</p>
                  <p>5 Extent</p>
                  <p>6 Commencement</p>
                  <p>7 Short title</p>
                  <p>Schedule</p>
