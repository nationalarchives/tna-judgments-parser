    <preface>
      <p><b>NUCLEAR SAFEGUARDS</b><b> </b><b>ACT 2018</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2018/15/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
