              <tr>
                <td colspan="5">
                  <p><b>Chapter 2 - Licensing of operators for vehicle use without user-in-charge</b></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 12-13 (licensing of operators)</p>
                </td>
