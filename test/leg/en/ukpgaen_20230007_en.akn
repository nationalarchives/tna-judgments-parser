    <preface>
      <p><b>SOCIAL SECURITY (ADDITIONAL PAYMENTS)</b><b> </b><b>ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/7/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
