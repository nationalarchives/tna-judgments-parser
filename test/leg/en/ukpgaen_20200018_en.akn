          <mainBody>
            <p eId="annex_1_p_7"><b>Annex A - Territorial extent and application in the United Kingdom</b></p>
            <table uk:widths="1.24in 0.01in 0.69in 0.06in 0.61in 0.01in 0.87in 0.01in 0.75in 0.01in 0.76in">
              <tr>
                <th colspan="2">
                  <p><b>Provision</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </th>
                <th colspan="3">
                  <p><b>Extends to E &amp; W and applies to Wales?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Scotland?</b></p>
                </th>
                <th colspan="2">
                  <p><b>Extends and applies to Northern Ireland?</b></p>
                </th>
                <th colspan="2">
                  <p><b>Legislative Consent Motion needed?</b></p>
                </th>
              </tr>
              <tr>
                <td colspan="2">
                  <p>Section 1</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td colspan="3">
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td colspan="2">
                  <p>Yes</p>
                </td>
                <td colspan="2">
                  <p>No</p>
                </td>
              </tr>
              <tr>
                <td colspan="2">
                  <p>Section 2</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td colspan="3">
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td colspan="2">
                  <p>Yes</p>
                </td>
                <td colspan="2">
                  <p>No</p>
                </td>
              </tr>
              <tr>
                <td colspan="11">
                  <p>Schedule Part 1</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Paragraph 1</p>
                </td>
                <td colspan="3">
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td colspan="3">
                  <p>Yes</p>
                </td>
                <td colspan="2">
                  <p>Yes </p>
                </td>
                <td>
                  <p>No</p>
                </td>
              </tr>
              <tr>
                <td>
