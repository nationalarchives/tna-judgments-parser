    <preface>
      <p><b>NHS FUNDING ACT 2020</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/5/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
