          <mainBody>
            <p><span style="color:#0070C0"><b>Annex B – Hansard References</b></span></p>
            <blockContainer>
              <num>20 </num>
              <p><span style="color:#000000">The following table sets out the dates and Hansard references for each stage of the Act’s passage through Parliament.</span></p>
            </blockContainer>
            <table uk:widths="2.16in 1.28in 2.07in">
              <tr>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000"><b>Stage</b></span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000"><b>Date</b></span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000"><b>Hansard reference</b></span></p>
                </td>
              </tr>
              <tr>
                <td colspan="3" style="vertical-align:middle">
                  <p><span style="color:#000000"><i>House of Commons</i></span></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">Introduction</span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">20 June 2022</span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><a href="https://publications.parliament.uk/pa/bills/cbill/58-03/0038/220038.pdf"><span style="color:#0070C0"><u>Bill as introduced</u></span></a></p>
                  <p><a href="https://hansard.parliament.uk/Commons/2022-06-20/debates/2cf7d8c4-5ae5-448c-a8c5-698b98690c8f/CommonsChamber"><span style="color:#0070C0"><u>Vol. 716 col. 587</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">Second Reading</span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">15 July 2022</span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><a href="https://hansard.parliament.uk/commons/2022-07-15/debates/CA90344D-6950-45D4-A65F-02E72A0AEAC8/PensionsDashboards(ProhibitionOfIndemnification)Bill"><span style="color:#0070C0"><u>Vol. 718 col. 656</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">Public Bill Committee</span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">26 October 2022</span></p>
                </td>
                <td style="vertical-align:middle">
                  <p><a href="https://hansard.parliament.uk/commons/2022-10-26/debates/06fb1d41-650e-48ea-8144-a107557bada1/PensionsDashboards(ProhibitionOfIndemnification)Bill"><span style="color:#0070C0"><u>Col. 1</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td style="vertical-align:middle">
                  <p><span style="color:#000000">Third Reading</span></p>
