    <preface>
      <p><b>APPROVED PREMISES (SUBSTANCE TESTING)</b><b> </b><b>ACT</b><b> 2022</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/27/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
