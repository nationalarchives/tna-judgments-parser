    <preface>
      <p><b>EARLY PARLIAMENTARY GENERAL ELECTION</b><b> </b><b>ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/29/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
