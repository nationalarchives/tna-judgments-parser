    <preface>
      <p><b>SOCIAL SECURITY (UP-RATING OF BENEFITS)</b><b> </b><b>ACT 2020</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/23/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
