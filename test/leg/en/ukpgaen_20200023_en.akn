                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/Commons/2020-10-01/debates/BE63C2D2-B510-402A-8E66-60F45461F981/SocialSecurity(Up-RatingOfBenefits)Bill"><span style="color:#000000"><u>Vol. 681 Col. 572</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Report and Third Reading</span></p>
