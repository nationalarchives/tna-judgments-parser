      <section eId="section_9">
        <heading><b>Annex A - Territorial extent and application in the United Kingdom</b></heading>
        <paragraph>
          <num>105 </num>
          <content>
            <p>The Act will extend and apply to the whole of the United Kingdom, including Northern Ireland. </p>
            <table ukm:widths="1.18in 1.07in 1.07in 1.07in 1.46in">
              <tr>
                <th>
                  <p><b>Provision</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to Wales?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Scotland?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Northern Ireland?</b></p>
                </th>
              </tr>
              <tr>
                <td>
                  <p>Sections 1-12</p>
                </td>
                <td>
                  <p>Yes</p>
                  <p />
                </td>
                <td>
                  <p>Yes</p>
                  <p />
                </td>
                <td>
                  <p>Yes</p>
                  <p />
                </td>
                <td>
                  <p>Yes</p>
                  <p />
                </td>
              </tr>
              <tr>
                <td>
                  <p>Schedule 1</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>In part</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Schedules 2-4</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes </p>
                </td>
              </tr>
            </table>
          </content>
        </paragraph>
      </section>
