        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 13: Commencement</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Section 14: Short title</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Schedule: Minor and consequential amendments</inline></tocItem>
