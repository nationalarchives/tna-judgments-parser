                  <p><a href="https://hansard.parliament.uk/Lords/2021-06-23/debates/3168CF4A-3CC9-49AB-B239-B4B6332F3117/DormantAssetsBill(HL)"><span style="color:#1155CC"><u>Vol. 813 Col. 77GC</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Report </span></p>
                </td>
                <td>
                  <p><span style="color:#000000">16 November 2021</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/Lords/2021-11-16/debates/9CD42B5B-47FC-4451-B015-10C9CE0643F7/DormantAssetsBill(HL)"><span style="color:#1155CC"><u>Vol. 816 Col. 167</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p><span style="color:#000000">Third Reading</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">23 November 2021</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/Lords/2021-11-23/debates/6028E675-D6CF-4F38-BF7B-641AFC6598E6/DormantAssetsBill(HL)"><span style="color:#1155CC"><u>Vol. 816 Col. 740</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td colspan="3">
                  <p><span style="color:#000000"><i>House of Commons</i></span></p>
                </td>
              </tr>
              <tr>
