    <preface>
      <p><b>CHILD SUPPORT (ENFORCEMENT)</b><b> </b><b>ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/35/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
