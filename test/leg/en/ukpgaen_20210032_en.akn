    <preface>
      <p><b>SOCIAL SECURITY (UP-RATING OF BENEFITS) ACT 2021</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2021/32/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
