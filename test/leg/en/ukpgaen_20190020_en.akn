    <preface>
      <p><b>HOLOCAUST (RETURN OF CULTURAL OBJECTS) (AMENDMENT) ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2019/20/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
