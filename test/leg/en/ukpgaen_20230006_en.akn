                </td>
              </tr>
              <tr>
                <td>
                  <p>14 December 2022</p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/lords/2022-12-14/debates/00C4BF5A-C190-4DC0-8A3E-3036C6225A74/GeneticTechnology(PrecisionBreeding)Bill"><u>Vol. 826 Col. 707</u></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Report</p>
                </td>
                <td>
                  <p>25 January 2023</p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/lords/2023-01-25/debates/6D8A0914-F879-4480-B78F-8BBD8F4CE3E6/GeneticTechnology(PrecisionBreeding)Bill"><u>Vol. 827 Col. 218</u></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Third Reading</p>
                </td>
                <td>
                  <p>01 February 2023</p>
                </td>
