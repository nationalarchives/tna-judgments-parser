    <preface>
      <p><b>RATING (CORONAVIRUS) AND DIRECTORS DISQUALIFICATION (DISSOLVED COMPANIES)</b><b> </b><b>ACT 2021</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
