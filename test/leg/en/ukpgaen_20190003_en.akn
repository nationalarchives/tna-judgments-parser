      <section eId="section_8">
        <heading><b>Annex A – Glossary</b></heading>
        <level>
          <content>
            <table uk:widths="3.15in 3.15in">
              <tr>
                <td>
                  <p>ATTRNs</p>
                </td>
                <td>
                  <p>Anti-Terrorism Traffic Regulation Notices</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>ATTROs</p>
                </td>
                <td>
                  <p>Anti-Terrorism Traffic Regulation Orders</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>ECS</p>
                </td>
                <td>
