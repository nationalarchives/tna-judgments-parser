    <preface>
      <p><b>SHARK FINS ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/22/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/22/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/22/notes/section/2" level="2"><inline name="tocHeading">Policy Objectives</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/22/notes/section/3" level="2"><inline name="tocHeading">Legal background</inline></tocItem>
