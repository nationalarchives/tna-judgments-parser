    <preface>
      <p><b>EUROPEAN UNION (APPROVALS)</b><b> </b><b>ACT 2017</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2017/35/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
