          <mainBody>
            <p><span style="color:#0070C0"><b>Annex B – Hansard References</b></span></p>
            <blockContainer>
              <num>71 </num>
              <p><span style="color:#000000">The following table sets out the dates and Hansard references for each stage of the Act's passage through Parliament. </span></p>
            </blockContainer>
            <table uk:widths="1.97in 1.48in 2.99in">
              <tr>
                <th>
                  <p><span style="color:#000000"><b>Stage</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Date</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Hansard Reference</b></span></p>
                </th>
              </tr>
              <tr>
                <td colspan="3">
                  <p><i>House of Commons</i><span style="color:#000000"> </span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Introduction</p>
                </td>
                <td>
                  <p><span style="color:#000000">25 March 2020</span></p>
                </td>
                <td>
                  <p><span style="color:#000000">No debate</span></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Second Reading </p>
                </td>
                <td>
                  <p><span style="color:#000000">8 June 2020</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2020-06-08/debates/09B51B40-1E0B-4513-877D-CF836DB67F75/DivorceDissolutionAndSeparationBill(Lords)"><span style="color:#000000"><u>Vol. 677 Col. 95</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Money Resolution</p>
                </td>
                <td>
                  <p><span style="color:#000000">8 June 2020</span></p>
                </td>
                <td>
                  <p><a href="https://hansard.parliament.uk/commons/2020-06-08/debates/09B51B40-1E0B-4513-877D-CF836DB67F75/DivorceDissolutionAndSeparationBill(Lords)#contribution-BDF10C21-D541-43BF-A3AB-1E0820B3FDD5" title=""><span style="color:#000000"><u>Vol. 677 Col. 95</u></span></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Programme Motion</p>
                </td>
                <td>
                  <p><span style="color:#000000">8 June 2020</span></p>
