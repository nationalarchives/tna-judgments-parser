    <preface>
      <p><b>DIVORCE, DISSOLUTION AND SEPARATION ACT 2020</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/11/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/11/notes/section/1" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2020/11/notes/section/2" level="2"><inline name="tocHeading">Legal background</inline></tocItem>
