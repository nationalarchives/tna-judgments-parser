    <preface>
      <p><b>THE LORDS SPIRITUAL (WOMEN) ACT 2015 (EXTENSION) ACT 2025</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
