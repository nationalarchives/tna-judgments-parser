        <tocItem href="http://www.legislation.gov.uk/ukpga/2021/16/notes/section/4" level="2"><inline name="tocHeading">Territorial extent and application</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2021/16/notes/section/5" level="2"><inline name="tocHeading">Commentary on provisions of Act</inline></tocItem>
