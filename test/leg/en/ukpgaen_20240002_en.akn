    <preface>
      <p><b>NORTHERN IRELAND (EXECUTIVE FORMATION) ACT 2024</b></p>
      <p>EXPLANATORY NOTES </p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2024/2/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
