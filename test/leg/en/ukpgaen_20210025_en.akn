        <tocItem href="#section_5" level="3"><inline name="tocHeading">Chapter 3: Approval of notifiable acquisition</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Chapter 4: Procedure</inline></tocItem>
        <tocItem href="#section_5" level="3"><inline name="tocHeading">Information gateways</inline></tocItem>
