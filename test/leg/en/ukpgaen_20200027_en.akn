          <mainBody>
            <p eId="annex_1_p_8"><b>Annex A - Territorial extent and application in the United Kingdom</b></p>
            <table uk:widths="1.87in 1.08in 1.08in 1.08in 1.08in">
              <tr>
                <th>
                  <p><b>Provision</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </th>
                <th>
                  <p><b>Extends to E &amp; W and applies to Wales?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Scotland?</b></p>
                </th>
                <th>
                  <p><b>Extends and applies to Northern Ireland?</b></p>
                </th>
              </tr>
              <tr>
                <td>
                  <p>Part 1: UK MARKET ACCESS: GOODS</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Part 2: UK MARKET ACCESS: SERVICES</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Part 3: PROFESSIONAL QUALIFICATIONS AND REGULATION</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Part 4: INDEPENDENT ADVICE ON AND MONITORING OF UK INTERNAL MARKET</p>
