          <mainBody>
            <p eId="annex_1_p_8"><b>Annex A – Territorial extent and application in the United Kingdom</b></p>
            <table uk:widths="1.86in 1.05in 1.05in 1.05in 1.05in">
              <tr>
                <td>
                  <p><b>Provision</b></p>
                </td>
                <td>
                  <p><b>Extends to E &amp; W and applies to England?</b></p>
                </td>
                <td>
                  <p><b>Extends to E &amp; W and applies to Wales?</b></p>
                </td>
                <td>
                  <p><b>Extends and applies to Scotland?</b></p>
                </td>
                <td>
                  <p><b>Extends and applies to Northern Ireland?</b></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 1 (Reports of the Boundary Commissions) </p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 2  (Orders in Council giving effect to reports)</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 3  (Modifications of recommendations in reports) </p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 4  (Publicity and consultation)</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 5  (Number of parliamentary constituencies)</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
                <td>
                  <p>Yes</p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Section 6 (Taking account of local government boundaries)</p>
