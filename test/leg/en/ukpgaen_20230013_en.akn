          <mainBody>
            <p eId="annex_2_p_9"><b>Annex B – Hansard References</b></p>
            <table uk:widths="0.96in 1.31in 0.98in 3.64in">
              <tr>
                <td>
                  <p><b>Stage</b></p>
                </td>
                <td>
                  <p><b>Date</b></p>
                </td>
                <td>
                  <p><b>Hansard Reference</b></p>
                </td>
                <td>
                  <p><b>Hansard Hyperlink</b></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Commons 1st Reading</p>
                </td>
                <td>
                  <p>15 June 2022</p>
                </td>
                <td>
                  <p />
                </td>
