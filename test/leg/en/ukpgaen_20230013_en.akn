    <preface>
      <p><b>EMPLOYMENT (ALLOCATION OF TIPS)</b><b> </b><b>ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes/section/2" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes/section/3" level="2"><inline name="tocHeading">Public consultation</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes/section/4" level="2"><inline name="tocHeading">Legal background</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes/section/5" level="2"><inline name="tocHeading">Territorial extent and application</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2023/13/notes/section/6" level="2"><inline name="tocHeading">Commonly used terms</inline></tocItem>
