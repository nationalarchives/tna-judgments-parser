    <preface>
      <p><span style="color:#000000"><b>TRADE (COMPREHENSIVE AND PROGRESSIVE AGREEMENT FOR TRANS-PACIFIC PARTNERSHIP) ACT 2024</b></span></p>
      <p><span style="color:#000000">EXPLANATORY NOTES</span></p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2024/6/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
