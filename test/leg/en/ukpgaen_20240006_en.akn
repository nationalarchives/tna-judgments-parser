    <preface>
      <p><b>TRADE (COMPREHENSIVE AND PROGRESSIVE AGREEMENT FOR TRANS-PACIFIC PARTNERSHIP) ACT 2024</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
