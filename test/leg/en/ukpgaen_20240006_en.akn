                </td>
              </tr>
              <tr>
                <td>
                  <p>14 December 2023</p>
                </td>
                <td>
                  <p>House of Lords <a href="https://hansard.parliament.uk/Lords/2023-12-14/debates/C017293A-B834-4C83-AE4E-2596386DED89/Trade(ComprehensiveAndProgressiveAgreementForTrans-PacificPartnership)Bill(HL)"><u>Vol. 834 Col. 325GC</u></a></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p>Report</p>
                </td>
