          <mainBody>
            <p><span style="color:#0070C0"><b>Annex B – Hansard References</b></span></p>
            <blockContainer>
              <num>21 </num>
              <p><span style="color:#000000">The following table sets out the dates and Hansard references for each stage of the Act's passage through Parliament. </span></p>
            </blockContainer>
            <table uk:widths="1.75in 1.48in 3.22in">
              <tr>
                <th>
                  <p><span style="color:#000000"><b>Stage</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Date</b></span></p>
                </th>
                <th>
                  <p><span style="color:#000000"><b>Hansard Reference</b></span></p>
                </th>
              </tr>
              <tr>
                <th colspan="3">
                  <p><i>House of Commons</i></p>
                </th>
              </tr>
              <tr>
                <th>
                  <p>Introduction</p>
                </th>
                <th>
                  <p>29 June 2023</p>
                </th>
                <th>
                  <p><a href="https://hansard.parliament.uk/commons/2023-06-29/debates/8AD2CB57-7BC3-43F9-945D-E16373A503C5/BusinessOfTheHouse"><span style="color:#1155CC"><u>Vol. 735. Col. 438</u></span></a></p>
                </th>
              </tr>
              <tr>
                <th>
                  <p>Second Reading</p>
                </th>
                <th>
                  <p>10 July 2023</p>
                </th>
                <th>
                  <p><a href="https://hansard.parliament.uk/Commons/2023-07-10/debates/535D30A9-7738-4B77-A70D-14D8806BF2A0/NorthernIrelandBudget(No2)Bill"><span style="color:#1155CC"><u>Vol. 736 Col. 101</u></span></a></p>
                </th>
              </tr>
              <tr>
                <th>
                  <p>Committee of the Whole House</p>
                </th>
                <th>
                  <p>4 September 2023</p>
                </th>
                <th>
                  <p><a href="https://hansard.parliament.uk/commons/2023-09-04/debates/B5804B6D-4BA7-4EF6-85A6-F19DD7C5770B/NorthernIrelandBudget(No2)Bill"><span style="color:#1155CC"><u>Vol. 737 Col 140</u></span></a></p>
                </th>
              </tr>
              <tr>
                <th>
                  <p>Third Reading</p>
                </th>
                <th>
                  <p>4 September 2023</p>
                </th>
                <th>
                  <p><a href="https://hansard.parliament.uk/commons/2023-09-04/debates/B5804B6D-4BA7-4EF6-85A6-F19DD7C5770B/NorthernIrelandBudget(No2)Bill"><span style="color:#1155CC"><u>Vol. 737 Col 144</u></span></a></p>
