                </td>
              </tr>
              <tr>
                <td>
                  <p><b>Section 3</b></p>
                </td>
                <td>
                  <p>Extends to E &amp; W, but does not apply</p>
                </td>
                <td>
                  <p>Extends to E &amp; W, but does not apply</p>
                </td>
                <td>
