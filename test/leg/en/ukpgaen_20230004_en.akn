    <preface>
      <p><b>NORTHERN IRELAND (EXECUTIVE FORMATION AND ORGAN AND TISSUE DONATION) ACT 2023</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
