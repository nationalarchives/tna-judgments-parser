    <preface>
      <p><b>NON-DOMESTIC RATING (PREPARATION FOR DIGITAL SERVICES)</b><b> </b><b>ACT 2019</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
