    <preface>
      <p><b>SMALL CHARITABLE DONATIONS AND CHILDCARE PAYMENTS</b><b> </b><b>ACT 2017</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
