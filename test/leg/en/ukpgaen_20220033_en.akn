    <preface>
      <p><b>PENSION SCHEMES (CONVERSION OF GUARANTEED MINIMUM PENSIONS)</b><b> </b><b>ACT 2022</b></p>
      <p>EXPLANATORY NOTES</p>
    </preface>
    <mainBody>
      <toc>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/33/notes" level="1"><inline name="tocHeading">The whole Explanatory Note</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/33/notes/section/1" level="2"><inline name="tocHeading">Overview of the Act</inline></tocItem>
        <tocItem href="http://www.legislation.gov.uk/ukpga/2022/33/notes/section/2" level="2"><inline name="tocHeading">Policy background</inline></tocItem>
